{
  "gamekit-feature-analyst": [
    {
      "name": "tighten accepted goal",
      "expects": ["scope_in", "scope_out", "acceptance_criteria"]
    },
    {
      "name": "reject greenfield ideation drift",
      "expects": ["does not invent a new direction", "asks for clarified scope when blocked"]
    }
  ],
  "gamekit-placeholder-artist": [
    {
      "name": "publish placeholder catalog entries",
      "expects": [".claude-gamekit/project/docs/art/asset-catalog.md", "stable naming"]
    },
    {
      "name": "keep final art out of scope",
      "expects": ["graybox bias", "hands ABI gaps to gamekit-tech-art-contracts"]
    }
  ],
  "gamekit-tech-art-contracts": [
    {
      "name": "capture mount and scale ABI",
      "expects": ["socket_defs", "scale_rule", "pivot_rule"]
    },
    {
      "name": "document replacement constraints",
      "expects": ["replacement guide update", "material_slots"]
    }
  ],
  "gamekit-gameplay-engineer": [
    {
      "name": "implement against asset contracts",
      "expects": ["no hardcoded placeholder lock-in", "code changes"]
    },
    {
      "name": "leave engineering note only when needed",
      "expects": ["small scoped change", "white-box check"]
    }
  ],
  "gamekit-qa-verifier": [
    {
      "name": "turn criteria into tests before implementation",
      "expects": [".claude-gamekit/project/docs/qa/cases", "evidence_required"]
    },
    {
      "name": "emit ci_required when runtime is unavailable",
      "expects": ["VerifyResult", "next steps"]
    }
  ],
  "gamekit-research-scout": [
    {
      "name": "return cited short research summary",
      "expects": ["citations", "short summary"]
    },
    {
      "name": "avoid residency in every task",
      "expects": ["only used when external research matters", "no long dump"]
    }
  ],
  "gamekit-script-validator": [
    {
      "name": "exercise command and hook entrypoints",
      "expects": ["smoke coverage", "script execution evidence"]
    },
    {
      "name": "fix integration defects without drifting scope",
      "expects": ["script-focused change", "no gameplay redesign"]
    }
  ],
  "gamekit-release-manager": [
    {
      "name": "publish validated diff only",
      "expects": ["git status review", "commit hash"]
    },
    {
      "name": "avoid content edits during release",
      "expects": ["staging and push only", "clear release summary"]
    }
  ],
  "gamekit-bilingual-docs": [
    {
      "name": "write matching English and Chinese docs",
      "expects": ["english guide", "chinese guide"]
    },
    {
      "name": "explain architecture and usage accurately",
      "expects": ["commands", "design rationale", "installation"]
    }
  ],
  "gamekit-unity-integrator": [
    {
      "name": "record Unity-only constraints",
      "expects": ["CI or editor requirement", "prefab or scene note"]
    },
    {
      "name": "preserve asset ABI during integration",
      "expects": ["AssetContract alignment", "static audit path"]
    }
  ],
  "gamekit-godot-integrator": [
    {
      "name": "prefer headless checks",
      "expects": ["--headless bias", "export awareness"]
    },
    {
      "name": "document Godot-specific scene constraints",
      "expects": ["engine note", "shared ABI preserved"]
    }
  ],
  "gamekit-web-integrator": [
    {
      "name": "treat browser evidence as first class",
      "expects": ["browser smoke", "evidence path"]
    },
    {
      "name": "preserve replaceable interfaces",
      "expects": ["shared contract alignment", "build note"]
    }
  ],
  "gamekit-wechat-integrator": [
    {
      "name": "document toolchain constraints",
      "expects": ["DevTools or CI note", "adapter constraints"]
    },
    {
      "name": "avoid undocumented platform divergence",
      "expects": ["shared ABI preserved", "explicit exception only"]
    }
  ]
}
