{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WorkItemRecord",
  "type": "object",
  "required": [
    "work_id",
    "task_id",
    "agent",
    "goal",
    "write_scope",
    "read_scope",
    "depends_on",
    "outputs",
    "status"
  ],
  "properties": {
    "work_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "agent": { "type": "string", "minLength": 1 },
    "goal": { "type": "string", "minLength": 1 },
    "write_scope": {
      "type": "array",
      "items": { "type": "string" }
    },
    "read_scope": {
      "type": "array",
      "items": { "type": "string" }
    },
    "depends_on": {
      "type": "array",
      "items": { "type": "string" }
    },
    "outputs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "status": { "type": "string", "minLength": 1 }
  }
}
